# ContentForge Production Environment Template
# Copy this to .env.production and fill in your actual API keys
# Last updated: 2024-04-18T19:30:00Z

# OpenRouter - Universal LLM Access (100+ models)
OPENROUTER_KEY=your_key_here
OPENROUTER_URL=https://openrouter.ai/api/v1

# Groq - Ultra-Fast Inference
GROQ_KEY=your_key_here
GROQ_URL=https://api.groq.com/openai/v1

# Claude (Anthropic) - Best Reasoning
CLAUDE_KEY=your_key_here
CLAUDE_URL=https://api.anthropic.com

# Mistral - EU Alternative
MISTRAL_KEY=your_key_here
MISTRAL_URL=https://api.mistral.ai/v1

# Supabase - Database + Storage
SUPADATA_KEY=your_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_key_here

# Google OAuth - Sign-in with Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Agent Configuration
AGENT_LOG_LEVEL=debug
AGENT_TIMEOUT_MS=30000
AGENT_MAX_RETRIES=3

# Multi-Provider Routing
PRIMARY_IMAGE_PROVIDER=openrouter
FALLBACK_IMAGE_PROVIDERS=stability,huggingface
PRIMARY_VIDEO_PROVIDER=animatediff
FALLBACK_VIDEO_PROVIDERS=openrouter,haiper
PRIMARY_TEXT_PROVIDER=claude
FALLBACK_TEXT_PROVIDERS=openrouter,groq

# Circuit Breaker Settings
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=60000

# Dashboard/Admin
ADMIN_DASHBOARD_ENABLED=true
ADMIN_SECRET_KEY=changeme_in_production
REAL_TIME_UPDATES=true

# Feature Flags
MULTI_AGENT_ENABLED=true
SCHEDULING_ENABLED=true
ANALYTICS_ENABLED=true
VIDEO_GENERATION_ENABLED=true

# Next.js / Vercel
NEXT_PUBLIC_APP_URL=https://contentforge.vercel.app
NODE_ENV=production
